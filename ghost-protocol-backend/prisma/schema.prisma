generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  teamId    String
  email     String   @unique
  password  String
  role      Role     @default(PARTICIPANT)
  result    Result?
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])
}

model Admin {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String   @default("")
  createdAt   DateTime @default(now())
  createdById String?
}

model Team {
  id             String   @id @default(cuid())
  name           String   @unique
  repoUrl        String?
  phase1Pass     Boolean  @default(false)
  phase2Pass     Boolean  @default(false)
  createdAt      DateTime @default(now())
  resultOverride Result?
  isAdminTeam    Boolean  @default(false)
  members        User[]
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum Role {
  PARTICIPANT
  ADMIN
}

enum Result {
  WINNER
  LOSER
}
