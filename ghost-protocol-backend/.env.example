# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/ghost_protocol"

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Redis (for BullMQ + Socket.IO adapter)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# GitHub OAuth App (for participant GitHub stats)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Admin
ADMIN_SECRET=super_admin_bootstrap_key
